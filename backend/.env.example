# ═══════════════════════════════════════════════
# e-Merkato Environment Variables
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════

# ── Server ──────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Supabase Database ────────────────────────────
# Found in: Supabase Dashboard → Project Settings → Database → Connection string
#
# IMPORTANT: On Vercel use the DIRECT connection (port 5432), NOT the pgbouncer
# pooler (port 6543). The pooler hostname is region-specific and causes ENOTFOUND
# when Vercel's region (e.g. iad1) doesn't match your Supabase region (e.g. eu-west-2).
# The direct connection works globally; the API uses a small pool (max:3), which is
# safe within Supabase's free-tier 60-connection limit.
#
# Format:  postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
#
DATABASE_URL=postgresql://postgres.[password]@db.[project-ref].supabase.co:5432/postgres
#
# For migrations/seeds you can reuse the same direct URL:
SUPABASE_DB_URL=postgresql://postgres.[password]@db.[project-ref].supabase.co:5432/postgres
#
# Supabase project URL and anon key (for future Supabase JS client usage):
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ── JWT ──────────────────────────────────────────
# Generate a strong random secret: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_with_64_char_random_hex_string_generate_with_command_above
JWT_EXPIRES_IN=7d

# ── Telegram Bot ─────────────────────────────────
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_BOT_USERNAME=eMerkatoBot

# ── Browser testing (optional) ──────────────────
# Set to "true" to allow `mock:<tg_user_id>` initData in production so you can
# test the app in a normal browser (outside Telegram WebView).
# !!! REMOVE in real production — it bypasses HMAC auth. !!!
BYPASS_TELEGRAM_AUTH=false

# ── Telebirr Payment Gateway ─────────────────────
# Apply for merchant API at https://ethiotelecom.et
TELEBIRR_APP_ID=your_telebirr_app_id
TELEBIRR_APP_SECRET=your_telebirr_app_secret
TELEBIRR_SHORT_CODE=your_platform_shortcode
TELEBIRR_BASE_URL=https://196.188.120.3:38443/ammapi/payment/service-openup

# ── Chapa Payment Gateway ────────────────────────
# Sign up at https://chapa.co — free sandbox available
CHAPA_SECRET_KEY=your_chapa_secret_key_here
CHAPA_BASE_URL=https://api.chapa.co/v1

# ── App URLs ─────────────────────────────────────
# In production: your Vercel deployment URL
APP_URL=https://emerkato.vercel.app
FRONTEND_URL=https://emerkato.vercel.app
PLATFORM_NAME=e-Merkato
